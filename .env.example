# WiGuard Nexus v5.5 Packet Tracer Intelligence
# Copy this file to .env for local use. Do not commit real secrets.

# ---- Development defaults ----
WIGUARD_ENV=development
WIGUARD_SECRET_KEY=change-me-local-dev-secret
WIGUARD_AUTH_REQUIRED=1
WIGUARD_REGISTRATION_ENABLED=1
WIGUARD_DISABLE_DEMO_FALLBACK=0
WIGUARD_DEFAULT_TENANT_ID=tenant-main

# ---- Production hardening ----
# WIGUARD_ENV=production
# WIGUARD_SECRET_KEY=replace-with-64-random-chars
# WIGUARD_DISABLE_DEMO_FALLBACK=1
# WIGUARD_REGISTRATION_ENABLED=0
# WIGUARD_SESSION_COOKIE_SECURE=1
# WIGUARD_MAX_UPLOAD_BYTES=20971520

# ---- Local admin fallback for development only ----
WIGUARD_ADMIN_USERNAME=admin
WIGUARD_ADMIN_PASSWORD=admin123
# Prefer WIGUARD_ADMIN_PASSWORD_HASH in production-like demos.

# ---- Database ----
WIGUARD_DB_BACKEND=sqlite
WIGUARD_DB_PATH=data/wiguard.sqlite3
# Future PostgreSQL mode:
# WIGUARD_DB_BACKEND=postgresql
# DATABASE_URL=postgresql://wiguard:strong-password@localhost:5432/wiguard

# ---- Paths ----
WIGUARD_DATA_FILE=data/state.json
WIGUARD_ARTIFACT_DIR=data/artifacts
WIGUARD_UPLOAD_DIR=data/uploads
WIGUARD_REPORT_DIR=data/reports
WIGUARD_SAMPLE_DIR=data/samples

# ---- Login rate limit ----
WIGUARD_LOGIN_MAX_FAILURES=5
WIGUARD_LOGIN_RATE_WINDOW_SECONDS=900
WIGUARD_SESSION_SECONDS=3600

# ---- Optional Packet Tracer conversion helper ----
# Configure if you use a local external converter that accepts input.pkt output.xml.
# PTEXPLORER_PATH=C:\Tools\pt-explorer\pt-explorer.exe
