# WiGuard Nexus production runtime
WIGUARD_ENV=production
WIGUARD_SECRET_KEY=change-this-to-a-long-random-secret
WIGUARD_AUTH_REQUIRED=1
WIGUARD_ADMIN_USERNAME=admin
# Generate with: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('StrongPasswordHere'))"
WIGUARD_ADMIN_PASSWORD_HASH=
WIGUARD_MAX_UPLOAD_BYTES=20971520
WIGUARD_HOST=127.0.0.1
WIGUARD_PORT=5000
FLASK_DEBUG=0

# v5.2 application database and registration
WIGUARD_DB_PATH=data/wiguard.sqlite3
WIGUARD_REGISTRATION_ENABLED=true

# Set to 1 after creating a SQLite admin account in production.
WIGUARD_DISABLE_DEMO_FALLBACK=0

# v5.3 security/product settings
WIGUARD_ENV=development
WIGUARD_LOGIN_MAX_FAILURES=5
WIGUARD_LOGIN_RATE_WINDOW_SECONDS=900
WIGUARD_SESSION_SECONDS=3600
WIGUARD_DISABLE_DEMO_FALLBACK=0
# For production set:
# WIGUARD_ENV=production
# WIGUARD_DISABLE_DEMO_FALLBACK=1
# WIGUARD_SECRET_KEY=<strong-random-secret>
